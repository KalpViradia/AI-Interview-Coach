# ===== AI Interview Coach — Backend Environment Variables =====

# --- Application ---
# Enable debug mode during local development
DEBUG=true

# --- Database (PostgreSQL) ---
# Use Supabase, Neon, or local Docker Postgres
DATABASE_URL=postgresql://username:password@localhost:5432/ai_interview_coach

# --- Gemini API ---
# Al Interview Coach
GEMINI_API_KEY=your_gemini_api_key

# --- ChromaDB ---
CHROMA_PERSIST_DIRECTORY=./chroma_db

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Auth ---
# Must match the NEXTAUTH_SECRET in frontend/.env.local
NEXTAUTH_SECRET=your_nextauth_secret

# --- Telemetry ---
ANONYMIZED_TELEMETRY=False
